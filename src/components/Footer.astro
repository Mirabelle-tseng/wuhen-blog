---
import ConsultCTA from './ConsultCTA.astro';
const today = new Date();
---

<footer>
	<ConsultCTA />
	<div class="clinic-block">
		<div class="clinic-info">
			<h3>無痕美學診所</h3>
			<p>台北市大安區安和路一段86號2樓</p>
			<p><a href="tel:+886227555673">02-2755-5673</a></p>
			<p>營業時間：週一～週六 10:00–18:00，週日公休</p>
			<p>
				<a href="https://lin.ee/n23vCCu" target="_blank" rel="noopener noreferrer">LINE 預約</a>
			</p>
		</div>
		<div class="clinic-map">
			<iframe
				src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3614.9806969457322!2d121.54976897358911!3d25.03472913826549!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442ab030cb7b205%3A0x6041c88c60cc65f!2z54Sh55eV576O5a246Ki65omA!5e0!3m2!1szh-TW!2stw!4v1782903602674!5m2!1szh-TW!2stw"
				style="border:0;"
				allowfullscreen
				loading="lazy"
				referrerpolicy="strict-origin-when-cross-origin"
			></iframe>
		</div>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} 無痕美學診所 版權所有。</p>
</footer>
<style>
	footer {
		padding: 3em 1em 5em 1em;
		background: var(--bg);
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		text-align: center;
	}
	.clinic-block {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 3rem;
		max-width: 720px;
		margin: 3.5rem auto 0;
		text-align: left;
	}
	.clinic-info {
		flex: 1 1 260px;
	}
	.clinic-info h3 {
		font-family: var(--font-serif);
		color: rgb(var(--black));
		margin: 0 0 0.9rem;
		font-size: 1.25em;
	}
	.clinic-info p {
		margin: 0 0 0.5rem;
	}
	.clinic-info p:last-child {
		margin-bottom: 0;
	}
	.clinic-info a {
		color: var(--accent);
	}
	.clinic-info a:hover {
		color: var(--accent-dark);
	}
	.clinic-map {
		flex: 1 1 320px;
	}
	.clinic-map iframe {
		display: block;
		width: 100%;
		height: 300px;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
	}
	.copyright {
		margin: 3rem 0 0;
	}
	@media (max-width: 720px) {
		.clinic-block {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 2.2rem;
		}
		.clinic-map,
		.clinic-info {
			width: 100%;
			max-width: 400px;
		}
	}
</style>
