---
interface Props {
	url: string;
}

const { url } = Astro.props;
const lineShareUrl = `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(url)}`;
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
---

<div class="share-buttons">
	<span class="share-label">分享這篇文章</span>
	<div class="share-links">
		<a
			class="share-button"
			href={lineShareUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="分享到 LINE"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18"
				><path
					fill="currentColor"
					d="M19.365 9.863c.349 0 .63.285.631.631 0 .345-.282.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.627.63H17.61v1.125zM15.5 13.508c0 .282-.19.518-.463.618a.652.652 0 0 1-.229.041c-.199 0-.397-.081-.541-.221l-.011-.011-.002-.002-2.484-3.346v2.882c0 .344-.281.629-.628.629-.348 0-.629-.285-.629-.629V8.108c0-.279.19-.518.463-.617a.615.615 0 0 1 .222-.041c.201 0 .39.081.535.229l.008.008.001.002 2.482 3.345V8.108c0-.345.283-.63.628-.63.348 0 .631.285.631.63v5.4zM8.078 8.108v5.4c0 .344-.281.629-.628.629-.349 0-.63-.285-.63-.629v-5.4c0-.345.281-.63.63-.63.347 0 .628.285.628.63zm-1.85 5.4c0 .344-.281.629-.628.629H3.213c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .629.285.629.63v4.771H5.6c.347 0 .628.281.628.63M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.037 9.608.391.084.923.258 1.058.592.121.303.079.778.038 1.084l-.164 1.02c-.045.301-.24 1.186 1.049.647 1.291-.54 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
				></path></svg
			>
			分享到 LINE
		</a>
		<a
			class="share-button"
			href={facebookShareUrl}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="分享到 Facebook"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18"
				><path
					fill="currentColor"
					d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036c-.264-.011-.531-.011-.795-.011-.522 0-.981.058-1.368.212-.36.135-.63.348-.813.653-.176.29-.28.657-.32 1.08-.033.362-.033.746-.033 1.152v.885h3.657l-.583 3.667h-3.074v7.98H9.101z"
				></path></svg
			>
			分享到 Facebook
		</a>
	</div>
</div>

<style>
	.share-buttons {
		margin: 3rem 0 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid rgb(var(--gray-light));
		text-align: center;
	}
	.share-label {
		display: block;
		margin-bottom: 1rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		letter-spacing: 0.04em;
	}
	.share-links {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.share-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.55em 1.3em;
		border: 1px solid var(--accent);
		border-radius: 999px;
		color: var(--accent);
		font-size: 0.9rem;
		text-decoration: none;
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
	}
	.share-button:hover {
		background: var(--accent);
		color: #fff;
	}
</style>
