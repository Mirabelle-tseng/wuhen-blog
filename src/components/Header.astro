<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	h2 {
		margin: 0;
		font-size: 1em;
		font-family: var(--font-serif);
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links a {
		align-items: center;
		padding: 0.5em;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
